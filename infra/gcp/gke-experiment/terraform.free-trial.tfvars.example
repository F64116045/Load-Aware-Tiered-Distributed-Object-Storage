# Free Trial constrained pilot profile.
#
# Copy this file to terraform.tfvars when the project has a 16-vCPU
# CPUS_ALL_REGIONS quota.
#
# This preserves the 6-storage-node topology while reserving two system nodes
# for API, metadata, TiKV/PD, tiering worker, and benchmark workload pods.
project_id = "project-f479bd33-201d-45a8-9d9"

region       = "asia-east1"
zone         = "asia-east1-a"
cluster_name = "rec-store-exp"

system_node_count  = 2
storage_node_count = 6
machine_type       = "n2-standard-2"
node_disk_type     = "pd-balanced"
node_disk_size_gb  = 30

artifact_registry_repository_id     = "rec-store"
create_artifact_registry_repository = false

labels = {
  owner   = "eason"
  profile = "split-pools"
}
