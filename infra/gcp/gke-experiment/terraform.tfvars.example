# Copy this file to terraform.tfvars and edit project_id before running apply.
project_id = "project-f479bd33-201d-45a8-9d9"

region       = "asia-east1"
zone         = "asia-east1-a"
cluster_name = "rec-store-exp"

# Pilot profile: less noisy than e2-standard-2 while keeping cost controlled.
node_count        = 6
machine_type      = "n2-standard-4"
node_disk_type    = "pd-balanced"
node_disk_size_gb = 50

# If the repository already exists from a previous gcloud setup, keep this false.
# For a fresh project, set true and Terraform will create it.
artifact_registry_repository_id     = "rec-store"
create_artifact_registry_repository = false

labels = {
  owner = "eason"
}
